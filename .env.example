# ===========================
# PROJET BLOCUS - CONFIGURATION
# ===========================
# Copie cette file en .env et remplis tes valeurs

# 🔑 SUPABASE CONFIGURATION
# Récupère ces valeurs sur https://app.supabase.com/
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 📱 APP CONFIGURATION
VITE_APP_NAME=Projet Blocus
VITE_APP_VERSION=2.0.0
VITE_APP_ENV=development

# 📊 FEATURES (optionnel)
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=true
VITE_ENABLE_SERVICE_WORKER=false

# 💬 VERCEL ANALYTICS (optionnel)
# Laisse vide si tu utilises pas Vercel Analytics
VITE_VERCEL_ANALYTICS_ID=

# 🌐 API ENDPOINTS (optionnel)
VITE_API_BASE_URL=http://localhost:5173

# ⚠️ IMPORTANT: 
# - NE COMMITE JAMAIS ce fichier (reste en .env local)
# - Les clés Supabase sont "public" mais protégées par row-level security (RLS)
# - Pour plus de sécurité, configure les policies Supabase correctement
